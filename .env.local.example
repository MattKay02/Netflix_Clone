# WHY THIS FILE EXISTS:
# .env.local is never committed (it's in .gitignore) because it contains your
# real TMDB API key. This .example file is committed instead — it documents
# which variables are required without exposing real values.
#
# HOW TO USE:
# 1. Copy this file:  cp .env.local.example .env.local
# 2. Replace the placeholder values with your real credentials
# 3. Get a free TMDB API key at: https://www.themoviedb.org/settings/api
#
# Vite exposes env vars prefixed with VITE_ to client-side code via
# import.meta.env. Variables without the VITE_ prefix are server-only
# and will NOT be available in the browser bundle.

VITE_TMDB_API_KEY=your_tmdb_api_key_here
VITE_TMDB_BASE_URL=https://api.themoviedb.org/3
VITE_TMDB_IMAGE_BASE=https://image.tmdb.org/t/p
